    {
      "id": "LvAvfCvOQCIBZRAahlTWI",
      "type": "text",
      "x": -161.6038693792293,
      "y": 3474.682210064576,
      "width": 1919.5943542146508,
      "height": 128.2221501947044,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ag",
      "roundness": null,
      "seed": 1601823050,
      "version": 323,
      "versionNonce": 257890698,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781554728175,
      "link": null,
      "locked": false,
      "text": "Because for better visualization browser console displays the document object in a \nspecial DOM tree view",
      "fontSize": 51.28886007788172,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because for better visualization browser console displays the document object in a \nspecial DOM tree view",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rqOymZdAF2V62Li_yJbG7",
      "type": "text",
      "x": -236.7787547125397,
      "y": 5347.882826730745,
      "width": 1805.978515625,
      "height": 64.11107509735216,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "agG",
      "roundness": null,
      "seed": 372934998,
      "version": 390,
      "versionNonce": 621347978,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781554728175,
      "link": null,
      "locked": false,
      "text": "Arrays are small objects, so Chrome can show all their properties immediately",
      "fontSize": 51.28886007788172,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Arrays are small objects, so Chrome can show all their properties immediately",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "v5KrqmqCUOW4AsF_yKLdx",
      "type": "text",
      "x": -240.08733054586924,
      "y": 5490.9685850640435,
      "width": 1813.1575927734375,
      "height": 128.2221501947043,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "agO",
      "roundness": null,
      "seed": 163441674,
      "version": 423,
      "versionNonce": 55305034,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781554728175,
      "link": null,
      "locked": false,
      "text": "But document is a massive object. If Chrome dumped all of them immediately, \nthe console would become unusable.",
      "fontSize": 51.28886007788172,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "But document is a massive object. If Chrome dumped all of them immediately, \nthe console would become unusable.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GylvQy1uThJYAH0jrasDj",
      "type": "text",
      "x": -509.3353763000149,
      "y": 9448.848481934321,
      "width": 2145.1245144661766,
      "height": 81.30080636385046,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "agS",
      "roundness": null,
      "seed": 1772700950,
      "version": 565,
      "versionNonce": 143650890,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781556048241,
      "link": null,
      "locked": false,
      "text": "If the variable contains one DOM node, traversal properties work directly.",
      "fontSize": 65.04064509108036,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the variable contains one DOM node, traversal properties work directly.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5z1MiOJBJHPeRyCXaq5v-",
      "type": "text",
      "x": -511.6839468455037,
      "y": 9572.750337484855,
      "width": 2820.7147453379757,
      "height": 81.30080636385046,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "agU",
      "roundness": null,
      "seed": 1281895830,
      "version": 581,
      "versionNonce": 1988056842,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781556048241,
      "link": null,
      "locked": false,
      "text": "If it contains many nodes (NodeList/HTMLCollection), first select one node, then traverse from it.",
      "fontSize": 65.04064509108036,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If it contains many nodes (NodeList/HTMLCollection), first select one node, then traverse from it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QwLsAfR7Pbc6U4jkIdB8-",
      "type": "text",
      "x": -166.89272945711082,
      "y": 3687.2596060965043,
      "width": 1357.124755859375,
      "height": 64.11107509735216,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "agV",
      "roundness": null,
      "seed": 827268426,
      "version": 407,
      "versionNonce": 1142380618,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781554728175,
      "link": null,
      "locked": false,
      "text": "It is very similar to how browser console displays the array",
      "fontSize": 51.28886007788172,
      "fontFamily": 6,
