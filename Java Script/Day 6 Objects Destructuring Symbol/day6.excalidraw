      "isDeleted": true,
      "boundElements": null,
      "updated": 1781524019776,
      "link": null,
      "locked": false,
      "text": "Using user[username] means there exists an\nvariable username",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Using user[username] means there exists an variable username",
