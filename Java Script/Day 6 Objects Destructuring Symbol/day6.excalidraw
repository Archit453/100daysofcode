    {
      "id": "JyoP6e_P1RCv2w25HNljL",
      "type": "text",
      "x": -3896.739734884488,
      "y": 1223.152013696492,
      "width": 837.1436767578125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#a6e3a1",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 454232728,
      "version": 158,
      "versionNonce": 663111832,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781523400926,
      "link": null,
      "locked": false,
      "text": "Because JS treats - as an subtraction operator, \nHence it will give SyntaxError: Unexpected token '-'",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because JS treats - as an subtraction operator, \nHence it will give SyntaxError: Unexpected token '-'",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XSxErLoTBmw94HGBGsSpr",
      "type": "text",
      "x": -4034.586826324345,
      "y": 2090.920052826009,
      "width": 1108.7996826171875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#a6e3a1",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "asV",
      "roundness": null,
      "seed": 1887884184,
      "version": 269,
      "versionNonce": 98954216,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781524061569,
      "link": null,
      "locked": false,
      "text": "Because bracket notation was invented for dynamic property access,\nUsing user[username] means there exists an variable username ,\nBut using user[\"username\"] means the username here is a key",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because bracket notation was invented for dynamic property access,\nUsing user[username] means there exists an variable username ,\nBut using user[\"username\"] means the username here is a key",
      "autoResize": true,
      "lineHeight": 1.25
    },
