    {
      "id": "aJmEJgd9ez1HHQB6D9xrA",
      "type": "text",
      "x": -1138.5716445823095,
      "y": 12490.85087180298,
      "width": 1165.2439917531774,
      "height": 87.52421420171048,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
