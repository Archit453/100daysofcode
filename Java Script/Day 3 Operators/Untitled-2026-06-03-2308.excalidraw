      "boundElements": null,
      "updated": 1780929889188,
      "link": null,
      "locked": false,
      "text": "The numbers 0.1, 0.2, and 0.3 cannot be\nperfectly represented in binary.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The numbers 0.1, 0.2, and 0.3 cannot be perfectly represented in binary.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "yskTOUUUW-OUxlkQSAac2",
      "type": "text",
      "x": -857.954158824492,
      "y": 15450.135175331416,
      "width": 779.4718017578125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "#1e1e2e",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b23",
      "roundness": null,
      "seed": 1816281960,
      "version": 25,
      "versionNonce": 1391214360,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780929915304,
      "link": null,
      "locked": false,
      "text": "The computer must cut off the infinite binary\nsequence, which creates tiny rounding errors for\neach number.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The computer must cut off the infinite binary sequence, which creates tiny rounding errors for each number.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "d-kTTEXlyRNs8lCd2M8Ny",
      "type": "text",
      "x": -840.1763878283982,
      "y": 15685.690717323603,
      "width": 779.4718017578125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "#1e1e2e",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b24",
      "roundness": null,
      "seed": 1730029416,
      "version": 69,
      "versionNonce": 107697688,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780929987135,
      "link": null,
      "locked": false,
      "text": "The tiny, individual errors from 0.1 and 0.2 add\nup to a final result that is different from the tiny\nerror produced when storing 0.3 directly.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The tiny, individual errors from 0.1 and 0.2 add up to a final result that is different from the tiny error produced when storing 0.3 directly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
