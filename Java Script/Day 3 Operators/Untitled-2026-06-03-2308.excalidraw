      "text": "let postfix = 5;\nlet prefix = 5;\n\nconsole.log(postfix++); // Prints 5. `postfix` is now 6.\nconsole.log(postfix);   // Prints 6.\n\nconsole.log(++prefix); // Prints 6. `prefix` is now 6.\nconsole.log(prefix);   // Prints 6.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "let postfix = 5;\nlet prefix = 5;\n\nconsole.log(postfix++); // Prints 5. `postfix` is now 6.\nconsole.log(postfix);   // Prints 6.\n\nconsole.log(++prefix); // Prints 6. `prefix` is now 6.\nconsole.log(prefix);   // Prints 6.",
      "autoResize": true,
      "lineHeight": 1.25
    },
