      "index": "b06",
      "roundness": null,
      "seed": 1128832616,
      "version": 26,
      "versionNonce": 237424152,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780920506010,
      "link": null,
      "locked": false,
      "text": "let result = 5 + 10;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "let result = 5 + 10;",
