      "isDeleted": false,
      "boundElements": null,
      "updated": 1780930255638,
      "link": null,
      "locked": false,
      "text": "JavaScript does it automatically behind the scenes. \nThis is what happens with the == operator. \nIt can be convenient but is often a source of bugs because it's\nnot obvious.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JavaScript does it automatically behind the scenes. \nThis is what happens with the == operator. \nIt can be convenient but is often a source of bugs because it's not obvious.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "5v4PhVUOwEocfKTphZR8s",
      "type": "text",
      "x": -868.0622128493246,
