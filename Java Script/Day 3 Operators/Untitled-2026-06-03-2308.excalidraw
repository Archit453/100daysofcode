      "isDeleted": false,
      "boundElements": null,
      "updated": 1780922717160,
      "link": null,
      "locked": false,
      "text": "If the left-hand operand is false, the\nright-hand operand is never evaluated.\nThis is a powerful feature for preventing\nerrors.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the left-hand operand is false, the right-hand operand is never evaluated. This is a powerful feature for preventing errors.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "9vCbAL_YYb1tXL8pQ7_XK",
      "type": "text",
      "x": -792.0222741748479,
      "y": 7756.993736836883,
      "width": 846.4439697265625,
      "height": 90,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1AG",
      "roundness": null,
      "seed": 1766199656,
      "version": 244,
      "versionNonce": 1233339240,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780923503059,
      "link": null,
      "locked": false,
      "text": "If the left-hand operand is true, the\nright-hand operand is never evaluated. ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the left-hand operand is true, the right-hand operand is never evaluated. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
