    {
      "id": "fadaZiSw8czfEKgeK9zLN",
      "type": "text",
      "x": -1040.3610965914495,
      "y": 22629.61762754744,
      "width": 955.6533151969313,
      "height": 36.11109924316406,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "#1e1e2e",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2b",
      "roundness": null,
      "seed": 1203937640,
      "version": 64,
      "versionNonce": 1910163560,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780931603310,
      "link": null,
      "locked": false,
      "text": "Here is a mental checklist you can follow when you see a comparison:",
      "fontSize": 28.88887939453125,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here is a mental checklist you can follow when you see a comparison:",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "acqfU09JNqdsKV01zktwW",
      "type": "text",
      "x": -1027.3711673922307,
      "y": 23252.117657170213,
      "width": 1007.0084339243507,
      "height": 82.99998779296875,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "#1e1e2e",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2c",
      "roundness": null,
      "seed": 1399699224,
      "version": 180,
      "versionNonce": 133580312,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780931651511,
      "link": null,
      "locked": false,
      "text": "This ordered breakdown reveals why the behavior is so complex: there are three distinct sets of\nrules, and the rules for loose equality (==) are very different from the rules for relational\ncomparisons (>=).",
      "fontSize": 22.133330078125002,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This ordered breakdown reveals why the behavior is so complex: there are three distinct sets of rules, and the rules for loose equality (==) are very different from the rules for relational comparisons (>=).",
      "autoResize": false,
      "lineHeight": 1.25
    }
