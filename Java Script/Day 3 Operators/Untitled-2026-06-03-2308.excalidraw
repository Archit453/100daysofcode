      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2BV",
      "roundness": null,
      "seed": 1592164888,
      "version": 110,
      "versionNonce": 1814598760,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780930333477,
      "link": null,
      "locked": false,
      "text": " You, the developer, intentionally write code to convert a value\nfrom one type to another. \nThis is the recommended, safe, and professional way to\nhandle type conversions.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " You, the developer, intentionally write code to convert a value from one type to another. \nThis is the recommended, safe, and professional way to handle type conversions.",
