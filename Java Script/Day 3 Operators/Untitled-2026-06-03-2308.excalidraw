      "isDeleted": true,
      "boundElements": null,
      "updated": 1780920506010,
      "link": null,
      "locked": false,
      "text": "// In this expression: 5 + 10",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// In this expression: 5 + 10",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VUG7VAV659N2Xp8R8vc0S",
      "type": "text",
      "x": -1242.2508819894333,
      "y": 1919.349885614315,
      "width": 514.7996826171875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b03",
      "roundness": null,
      "seed": 1060930072,
      "version": 26,
      "versionNonce": 653785448,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780920506010,
      "link": null,
      "locked": false,
      "text": "// -> `+` is the operator.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// -> `+` is the operator.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C0wzWPfKxgF04C94u8A_o",
      "type": "text",
      "x": -1341.250820954277,
      "y": 1974.349885614315,
      "width": 712.799560546875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 1112951656,
      "version": 26,
      "versionNonce": 1605153048,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780920506010,
      "link": null,
      "locked": false,
      "text": "// -> `5` and `10` are the operands.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// -> `5` and `10` are the operands.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VJKYJjjWBi3vsX_yJDcU-",
      "type": "text",
      "x": -1341.250820954277,
      "y": 2006.849885614315,
      "width": 712.799560546875,
      "height": 90,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b05",
      "roundness": null,
      "seed": 1838448408,
      "version": 26,
      "versionNonce": 1132760168,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780920506010,
      "link": null,
      "locked": false,
      "text": "// -> The entire expression `5 + 10`\nevaluates to the value `15`.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// -> The entire expression `5 + 10` evaluates to the value `15`.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "NPxEAn1UunPphSpZM3Uwu",
      "type": "text",
      "x": -1182.850918610527,
      "y": 2129.349885614315,
      "width": 395.999755859375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
