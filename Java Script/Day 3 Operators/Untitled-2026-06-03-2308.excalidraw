      "seed": 2000895336,
      "version": 793,
      "versionNonce": 1534162024,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780929750486,
      "link": null,
      "locked": false,
      "text": "Because :- The computer thinks in Base 2 (binary), but we are giving it a\nproblem in Base 10 (decimal). The translation is not perfect.",
      "fontSize": 35.00968568068419,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because :- The computer thinks in Base 2 (binary), but we are giving it a problem in Base 10 (decimal). The translation is not perfect.",
      "autoResize": false,
      "lineHeight": 1.25
    },
