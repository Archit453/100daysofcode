      "isDeleted": false,
      "boundElements": null,
      "updated": 1782286741482,
      "link": null,
      "locked": false,
      "text": "We can too do the same thing by using array --   arr.push\n                                                                                    .append(...arr) ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We can too do the same thing by using array --   arr.push\n                                                                                    .append(...arr) ",
