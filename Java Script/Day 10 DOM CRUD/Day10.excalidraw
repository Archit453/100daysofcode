      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Never use .innerHTML with content provided by a user (like a comment or a username). If a user enters malicious <script> code, .innerHTML will execute it, allowing the user to attack your website and its visitors.",
