      "seed": 2102812586,
      "version": 35,
      "versionNonce": 1357724522,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782285722981,
      "link": null,
      "locked": false,
      "text": "Still DocumentFragment is useful because it reduces live DOM mutations, \nnot necessarily reflow/repaint.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Still DocumentFragment is useful because it reduces live DOM mutations, \nnot necessarily reflow/repaint.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
