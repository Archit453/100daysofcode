      "isDeleted": false,
      "boundElements": null,
      "updated": 1782285178317,
      "link": null,
      "locked": false,
      "text": "But modern browsers does batch rendering and usually repaint only after \nJavaScript finishes execution.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "But modern browsers does batch rendering and usually repaint only after \nJavaScript finishes execution.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yPbdD6CYua1E-Ixf8En62",
      "type": "text",
      "x": -1531.7880858537023,
      "y": 7468.787835306977,
      "width": 1205.171630859375,
      "height": 90,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
