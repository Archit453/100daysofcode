      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582626852,
      "link": null,
      "locked": false,
      "text": "A heavyweight runtime for arbitrary C++ programs would have been\nimpractical.",
      "fontSize": 30.92061941964275,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A heavyweight runtime for arbitrary C++ programs would have been impractical.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "y9CS5MXMtTdUnqoRjejmX",
      "type": "text",
      "x": 742.2765449126474,
      "y": 16252.679831870057,
      "width": 854.2074562768787,
      "height": 68.83597237723127,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4Zx",
      "roundness": null,
      "seed": 1681863264,
      "version": 79,
      "versionNonce": 1244975742,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582626852,
      "link": null,
      "locked": false,
      "text": "JavaScript uses Garbage Collection, so developers do not manually\nallocate or free memory.",
      "fontSize": 27.53438895089251,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JavaScript uses Garbage Collection, so developers do not manually allocate or free memory.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "IE6j9NELEaXGydbQvnkSt",
      "type": "text",
      "x": 731.1251079706833,
      "y": 16347.64015901849,
      "width": 839.0769828314051,
      "height": 95.71426391601561,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4Zz",
      "roundness": null,
      "seed": 1749787552,
      "version": 76,
      "versionNonce": 1041636450,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582626852,
      "link": null,
      "locked": false,
      "text": "This reduces complexity and avoids common memory-management\nbugs such as memory leaks, dangling pointers, and double frees that are\ncommon in C++.",
      "fontSize": 25.523803710937496,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This reduces complexity and avoids common memory-management bugs such as memory leaks, dangling pointers, and double frees that are common in C++.",
      "autoResize": false,
      "lineHeight": 1.25
    },
