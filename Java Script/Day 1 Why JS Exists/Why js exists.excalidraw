      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "If we can use x86 (or ARM) as the target or JVM bytecode as target \nWhy do we necessarily need webassembly ?",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we can use x86 (or ARM) as the target or JVM bytecode as target \nWhy do we necessarily need webassembly ?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Q8Dgx_hQ3TDhpiYzeTbSE",
      "type": "text",
      "x": 595.5386531378056,
      "y": 13742.056688907851,
      "width": 1266.179085948261,
      "height": 180,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2s1",
      "roundness": null,
      "seed": 401298327,
      "version": 595,
      "versionNonce": 571079010,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "WebAssembly (abbreviated Wasm) is a binary instruction format for a \nstack-based virtual machine. Wasm is designed as a portable compilation\ntarget for programming languages, enabling deployment on the web for\nclient and server applications.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WebAssembly (abbreviated Wasm) is a binary instruction format for a \nstack-based virtual machine. Wasm is designed as a portable compilation target for programming languages, enabling deployment on the web for client and server applications.",
      "autoResize": false,
      "lineHeight": 1.25
    },
