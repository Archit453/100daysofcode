      "seed": 23512535,
      "version": 256,
      "versionNonce": 1370701602,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "They are eventually translated by their respective runtimes (JVM\nor WASM Runtime) into the machine code of the underlying CPU\narchitecture (x86, ARM, etc.).",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "They are eventually translated by their respective runtimes (JVM or WASM Runtime) into the machine code of the underlying CPU architecture (x86, ARM, etc.).",
      "autoResize": false,
      "lineHeight": 1.25
    },
