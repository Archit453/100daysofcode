      "text": "JVM Bytecode and WebAssembly are intermediate instruction sets.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JVM Bytecode and WebAssembly are intermediate instruction sets.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "NK9XoRGW83T7XHahemIhU",
      "type": "text",
      "x": 687.3084546954885,
      "y": 11336.462332105482,
      "width": 1080.8989112551787,
      "height": 135,
      "angle": 0,
      "strokeColor": "#cdd6f4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
