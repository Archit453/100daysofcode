      "index": "b2px",
      "roundness": null,
      "seed": 1036805143,
      "version": 390,
      "versionNonce": 1009159650,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "- Browsers cannot safely execute\narbitrary native binaries",
      "fontSize": 30.68131041147863,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Browsers cannot safely execute arbitrary native binaries",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "n7BeoAW9oU4Njr_oElNxJ",
      "type": "text",
      "x": 676.210467555763,
      "y": 8854.358674719406,
      "width": 1183.931640625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#a6e3a1",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2pz",
      "roundness": null,
      "seed": 1013600855,
      "version": 206,
      "versionNonce": 1773877566,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "So they decided to create a new target architecture called WebAssembly",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So they decided to create a new target architecture called WebAssembly",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "isfT9y14B9UryJ8VQsQ7c",
      "type": "text",
      "x": 665.0241574239254,
      "y": 8946.844464384047,
      "width": 392.11181640625,
      "height": 90,
      "angle": 0,
      "strokeColor": "#f9e2af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2q1",
      "roundness": null,
      "seed": 1101098711,
      "version": 386,
      "versionNonce": 228491682,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "What is webassembly ?\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is webassembly ?\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8v9RxYqml38udZpHelP1J",
      "type": "text",
      "x": 669.416501853458,
      "y": 9030.078550107319,
      "width": 1266.179085948261,
      "height": 180,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2q2",
      "roundness": null,
      "seed": 780916953,
      "version": 624,
      "versionNonce": 45965694,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "Web assembly is just a target architecture like \n                                       x86 Machine code \n                                       ARM Machine code\n                                       JVM Byte code",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Web assembly is just a target architecture like \n                                       x86 Machine code \n                                       ARM Machine code\n                                       JVM Byte code",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "o_cufJthnqXynvCnjmtXq",
      "type": "text",
      "x": 835.7762170987439,
      "y": 9274.399623558966,
      "width": 705.9957885742188,
      "height": 45,
      "angle": 0,
      "strokeColor": "#a6e3a1",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2q4",
      "roundness": null,
      "seed": 646685047,
      "version": 220,
      "versionNonce": 459406690,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106979,
      "link": null,
      "locked": false,
      "text": "x86 Machine Code  → Target for Intel CPUs",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "x86 Machine Code  → Target for Intel CPUs",
