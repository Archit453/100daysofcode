    },
    {
      "id": "Gzmm6X_NeIt2NbREgzRGd",
      "type": "text",
      "x": 894.142116728045,
      "y": 18154.713784420645,
      "width": 150.07665157590984,
      "height": 47.193943770800615,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4al",
      "roundness": null,
      "seed": 1712207650,
      "version": 147,
      "versionNonce": 60819042,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "Sandbox",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sandbox",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bLOFfQXoHOVZFdmlEC3YX",
      "type": "text",
      "x": 516.438601509396,
      "y": 18200.183501203708,
      "width": 1642.5206286277914,
      "height": 47.193943770800615,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4an",
      "roundness": null,
      "seed": 1919796222,
      "version": 215,
      "versionNonce": 185829566,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• Sandbox is a security mechanism implemented by the browser and the operating system.",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Sandbox is a security mechanism implemented by the browser and the operating system.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "eNVe7y0OaOkmJeRdxR4Gw",
      "type": "text",
      "x": 517.7244213619276,
      "y": 18309.513828424246,
      "width": 1543.6526022039786,
      "height": 94.38788754160123,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4ap",
      "roundness": null,
      "seed": 121570018,
      "version": 226,
      "versionNonce": 139782690,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• Before running JavaScript or WebAssembly, the browser creates a sandboxed process\nwith restricted permissions.",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Before running JavaScript or WebAssembly, the browser creates a sandboxed process with restricted permissions.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "hw3qlwBBznKOFR1-n6klS",
      "type": "text",
      "x": 523.4855184269854,
      "y": 18465.083849827006,
      "width": 1580.2788048837583,
      "height": 47.193943770800615,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4ar",
      "roundness": null,
      "seed": 1381012542,
      "version": 224,
      "versionNonce": 56606974,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• The JavaScript engine (V8, SpiderMonkey, etc.) runs inside this sandboxed process.",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• The JavaScript engine (V8, SpiderMonkey, etc.) runs inside this sandboxed process.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "wQZdIrbgqxcGmzvcQRoLZ",
      "type": "text",
      "x": 527.599680980818,
      "y": 18579.015449106104,
      "width": 738.71714644276,
      "height": 47.193943770800615,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4at",
      "roundness": null,
      "seed": 669013666,
      "version": 197,
      "versionNonce": 876041698,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• JavaScript → V8 → Machine Code → CPU",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• JavaScript → V8 → Machine Code → CPU",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AhN1Q4s_MSffhJwFzpq5r",
      "type": "text",
      "x": 525.6355967587426,
      "y": 18690.25427550378,
      "width": 1472.2746280379524,
      "height": 141.58183131240185,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4av",
      "roundness": null,
      "seed": 99572862,
      "version": 248,
      "versionNonce": 1308291390,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• If the executed code tries to access protected resources (files, system commands,\nother applications), the operating system enforces the sandbox restrictions and denies\naccess.",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• If the executed code tries to access protected resources (files, system commands, other applications), the operating system enforces the sandbox restrictions and denies access.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "RJnHnB9d7yF5B1kc_vWk5",
      "type": "text",
      "x": 519.4285707712083,
      "y": 18907.3559759091,
      "width": 1340.2445068359377,
      "height": 47.193943770800615,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4ax",
      "roundness": null,
      "seed": 413217378,
      "version": 226,
      "versionNonce": 1482049954,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780582652580,
      "link": null,
      "locked": false,
      "text": "• The sandbox protects the user's computer from malicious web pages.",
      "fontSize": 37.755155016640494,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• The sandbox protects the user's computer from malicious web pages.",
      "autoResize": false,
      "lineHeight": 1.25
    },
