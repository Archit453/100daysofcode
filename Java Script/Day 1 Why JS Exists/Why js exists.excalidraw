      "isDeleted": false,
      "boundElements": [],
      "updated": 1780578106980,
      "link": null,
      "locked": false,
      "text": "1. Browser Dependency :-\n             Every browser would need ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Browser Dependency :-\n             Every browser would need ",
