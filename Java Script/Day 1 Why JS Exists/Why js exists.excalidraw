    {
      "id": "uQ95zzYqyH_eyia8jtb2q",
      "type": "text",
      "x": 1229.7372674269652,
      "y": 8600.574212619,
      "width": 477.49832816327023,
      "height": 76.70327602869658,
      "angle": 0,
      "strokeColor": "#89b4fa",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
