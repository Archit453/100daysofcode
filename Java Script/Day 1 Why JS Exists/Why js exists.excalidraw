      "text": "1. Portability :- One x86 binary \n                    won't run everywhere. ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Portability :- One x86 binary \n                    won't run everywhere. ",
