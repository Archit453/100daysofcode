      "updated": 1780521312669,
      "link": null,
      "locked": false,
      "text": "Netscape partnered with Sun in 1995,\n",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Netscape partnered with Sun in 1995,\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "7zue62hDSQrsw5H4TDtQ8",
      "type": "rectangle",
